{
  "name": "spec-driven-agents",
  "displayName": "Specification-Driven Agents CLI",
  "version": "0.1.0",
  "description": "CLI tooling for Specification-Driven Agents framework - Generate, validate, and manage specification contracts",
  "homepage": "https://github.com/inseone1988/specification-driven-agents",
  "main": "dist/index.js",
  "type": "commonjs",
  "bin": {
    "sda": "./bin/sda.js"
  },
  "files": [
    "dist",
    "bin",
    "templates",
    "schemas",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts",
    "prepare": "npm run build",
    "prepublishOnly": "npm test"
  },
  "keywords": [
    "specification",
    "contract",
    "cli",
    "validation",
    "generation",
    "framework",
    "ai",
    "agent",
    "documentation",
    "yaml",
    "schema"
  ],
  "author": "Specification-Driven Agents Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/inseone1988/specification-driven-agents.git",
    "directory": "tooling"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "figlet": "^1.7.0",
    "glob": "^13.0.6",
    "js-yaml": "^4.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.11.24",
    "@typescript-eslint/eslint-plugin": "^7.1.0",
    "@typescript-eslint/parser": "^7.1.0",
    "eslint": "^8.57.0",
    "prettier": "^3.2.5",
    "tsup": "^8.0.2",
    "typescript": "^5.3.3",
    "vitest": "^1.3.1"
  }
}
